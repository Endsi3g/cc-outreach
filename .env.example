# ──────────────────────────────────────────────
# DATABASE
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cc_outreach"

# ──────────────────────────────────────────────
# REDIS
# ──────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ──────────────────────────────────────────────
# APP
# ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000
JWT_SECRET=change_me_in_production_minimum_32_chars
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────────────
# GOOGLE / GMAIL OAUTH
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GMAIL_SCOPES=https://mail.google.com/

# ──────────────────────────────────────────────
# OLLAMA
# ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1
OLLAMA_TIMEOUT_MS=60000

# ──────────────────────────────────────────────
# NOTIFICATIONS
# ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# ──────────────────────────────────────────────
# WORKERS
# ──────────────────────────────────────────────
WORKER_CONCURRENCY=3
WORKER_PORT=3001
SCHEDULER_PORT=3002

# ──────────────────────────────────────────────
# RATE LIMITING
# ──────────────────────────────────────────────
GMAIL_DAILY_QUOTA=450
CRAWL_DELAY_MS=1500
GOOGLE_MAPS_DELAY_MS=2000
